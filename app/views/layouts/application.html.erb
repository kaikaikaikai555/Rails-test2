<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Accommodation App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <% if notice %>
      <p style="color: green;"><%= notice %></p>
    <% end %>
    <% if alert %>
      <p style="color: red;"><%= alert %></p>
    <% end %>

    <header>
      <h1><%= link_to "宿泊予約アプリ", root_path %></h1>

      <% if user_signed_in? %>
        <div style="border: 1px solid #ccc; padding: 10px; display: inline-block;">
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar, size: "30x30", style: "border-radius: 50%;" %>
          <% else %>
            <%= image_tag "/default-avatar.png", size: "30x30", style: "border-radius: 50%;" %>
          <% end %>
          <strong><%= current_user.name %> さん</strong>
        
          <ul style="list-style: none; padding: 0; margin-top: 5px;">
            <li><%= link_to "プロフィール詳細", user_path(current_user) %></li>
            <li><%= link_to "プロフィール編集", edit_user_registration_path %></li>
            <li><%= button_to "ログアウト", destroy_user_session_path, method: :delete, style: "background: none; border: none; color: blue; text-decoration: underline; cursor: pointer; padding: 0;" %></li>
          </ul>
        </div>
      <% else %>
        <%= link_to "新規登録", new_user_registration_path %>
        <%= link_to "ログイン", new_user_session_path %>
      <% end %>
    </header>
    <hr>

    <%= yield %>
  </body>
</html>