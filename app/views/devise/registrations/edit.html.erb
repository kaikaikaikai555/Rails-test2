<h2>プロフィールの編集</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.label :avatar, "プロフィール画像" %><br />
    <%= f.file_field :avatar %>
  </div>

  <div class="field">
    <%= f.label :name, "名前" %><br />
    <%= f.text_field :name, autofocus: true %>
  </div>

  <div class="field">
    <%= f.label :introduction, "自己紹介" %><br />
    <%= f.text_area :introduction %>
  </div>

  <div class="field">
    <%= f.label :email, "Eメール" %><br />
    <%= f.email_field :email %>
  </div>

  <p style="color: #666; font-size: 0.9em;">※メールアドレス、パスワードを変更しない場合は空欄のままで更新できます。</p>

  <div class="field">
    <%= f.label :password, "新しいパスワード" %> <i>(変更する場合のみ入力)</i><br />
    <%= f.password_field :password, autocomplete: "new-password" %>
  </div>

  <div class="field">
    <%= f.label :password_confirmation, "新しいパスワード（確認用）" %><br />
    <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
  </div>

  <%# 「現在のパスワード」の入力欄を削除、またはコメントアウトしました %>

  <div class="actions">
    <%= f.submit "更新する" %>
  </div>
<% end %>