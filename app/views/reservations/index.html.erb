<h2>予約済み施設一覧</h2>

<table border="1">
  <thead>
    <tr>
      <th>施設画像</th>
      <th>施設名</th>
      <th>紹介文</th>
      <th>合計料金</th>
      <th>チェックイン</th>
      <th>チェックアウト</th>
      <th>予約確定日時</th>
    </tr>
  </thead>

  <tbody>
    <% @reservations.each do |reservation| %>
      <tr>
        <td>
          <% if reservation.room.image.attached? %>
            <%= image_tag reservation.room.image, size: "100x100" %>
          <% else %>
            <%= image_tag "default-image.png", size: "100x100" %>
          <% end %>
        </td>
        <td><%= reservation.room.name %></td>
        <td><%= reservation.room.introduction %></td>
        <td><%= reservation.total_price %>円</td> <%# 次のステップで作ります %>
        
        <%# yyyy/mm/dd の形式 %>
        <td><%= reservation.start_date.strftime('%Y/%m/%d') %></td>
        <td><%= reservation.end_date.strftime('%Y/%m/%d') %></td>
        
        <%# yyyy/mm/dd HH:MM の形式（予約確定日時） %>
        <td><%= reservation.created_at.strftime('%Y/%m/%d %H:%M') %></td>
      </tr>
    <% end %>
  </tbody>
</table>