<h2>施設検索結果</h2>
<p>検索結果：<%= @count %>件</p>

<table border="1">
  <thead>
    <tr>
      <th>施設画像</th>
      <th>施設名</th>
      <th>住所</th>
      <th>施設詳細</th>
      <th>宿泊料金</th>
    </tr>
  </thead>
  <tbody>
    <% @rooms.each do |room| %>
      <tr>
        <td>
          <% if room.image.attached? %>
            <%= image_tag room.image, size: "100x100" %>
          <% else %>
            <%= image_tag "default-image.png", size: "100x100" %>
          <% end %>
        </td>
        <td><%= link_to room.name, room_path(room) %></td>
        <td><%= room.address %></td>
        <td><%= room.introduction %></td>
        <td><%= room.price %>円</td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "戻る", :back %>