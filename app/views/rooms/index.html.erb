<h2>登録済み施設一覧</h2>

<p><%= link_to "新しい施設を登録する", new_room_path %></p>

<table border="1">
  <thead>
    <tr>
      <th>施設名</th>
      <th>紹介</th>
      <th>料金</th>
      <th>住所</th>
      <th>詳細</th>
    </tr>
  </thead>

  <tbody>
    <% @rooms.each do |room| %>
      <tr>
        <td>
          <% if room.image.attached? %>
            <%= image_tag room.image, size: "100x100" %>
          <% else %>
            <%= image_tag "default-image.png", size: "100x100" %>
          <% end %>
        </td>
        <td><%= room.name %></td>
        <td><%= room.introduction %></td>
        <td><%= room.price %>円</td>
        <td><%= room.address %></td>
        <td><%= link_to "詳細を見る", room_path(room) %></td>
      </tr>
    <% end %>
  </tbody>
</table>