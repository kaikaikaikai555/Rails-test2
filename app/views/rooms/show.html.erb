<h2>施設詳細</h2>

<div>
  <% if @room.image.attached? %>
    <%= image_tag @room.image, style: "width: 400px; height: auto;" %>
  <% else %>
    <%= image_tag "default-image.png", style: "width: 400px; height: auto;" %>
  <% end %>
</div>

<h3><%= @room.name %></h3>

<p><strong>紹介:</strong><br>
<%= simple_format(@room.introduction) %></p>

<p><strong>住所:</strong> <%= @room.address %></p>
<p><strong>宿泊料金:</strong> <%= @room.price %>円 / 1泊</p>

<hr>

<%= link_to "一覧に戻る", rooms_path %>
| <%= link_to "編集する", edit_room_path(@room) %>
<%= button_to "削除する", room_path(@room), method: :delete, data: { confirm: "本当に削除しますか？" } %>
<hr>
<h3>この施設を予約する</h3>

<%= form_with(model: [@room, Reservation.new], local: true) do |f| %>
  <div>
    <%= f.label :start_date, "チェックイン" %><br>
    <%= f.date_field :start_date %>
  </div>

  <div>
    <%= f.label :end_date, "チェックアウト" %><br>
    <%= f.date_field :end_date %>
  </div>

  <div>
    <%= f.label :count, "宿泊人数" %><br>
    <%= f.number_field :count %>
  </div>

  <div>
    <%= f.submit "予約を確定する" %>
  </div>
<% end %>