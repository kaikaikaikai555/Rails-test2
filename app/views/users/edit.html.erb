<h2>プロフィール編集</h2>

<%= form_with model: @user, url: user_path, local: true do |f| %>
  <div class="field">
    <%= f.label :image, "プロフィール画像" %><br />
    <%= f.file_field :image %>
  </div>

  <div class="field">
    <%= f.label :name, "名前" %><br />
    <%= f.text_field :name %>
  </div>

  <div class="field">
    <%= f.label :introduction, "自己紹介" %><br />
    <%= f.text_area :introduction %>
  </div>

  <div class="actions">
    <%= f.submit "プロフィールを更新する" %>
  </div>
<% end %>

<hr>
<%= link_to "マイページ（アカウント情報）に戻る", user_path %>